{
  "agent": "agent-derivatives-skew-sentiment-monitor",
  "state": "iv-premium-watch",
  "risk_level": "高关注",
  "execution_boundary": "research_and_monitoring_only",
  "rules": [
    {
      "id": "agent-derivatives-skew-sentiment-monitor.upgrade",
      "severity": "watch_upgrade",
      "condition": "IV-HV 差继续扩大，且高隐波集中在有解释力的到期或行权结构。",
      "action": "rerun_agent_and_add_to_research_backlog"
    },
    {
      "id": "agent-derivatives-skew-sentiment-monitor.degrade",
      "severity": "watch_degrade",
      "condition": "隐波快速回落，或历史波动率上升解释了大部分溢价。",
      "action": "lower_confidence_and_write_review_note"
    },
    {
      "id": "agent-derivatives-skew-sentiment-monitor.data_gap",
      "severity": "data_quality",
      "condition": "Pandadata 关键表行数低于本 Agent 需要的最低样本数",
      "action": "stop_and_mark_inconclusive"
    }
  ]
}
